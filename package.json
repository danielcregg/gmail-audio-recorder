{
  "name": "gmail-audio-recorder",
  "version": "1.0.0",
  "description": "Chrome extension — record and attach audio messages with live transcription in Gmail.",
  "private": true,
  "scripts": {
    "test": "jest --verbose --coverage",
    "test:ci": "jest --verbose --coverage --ci --reporters=default",
    "lint": "eslint src/ content.js",
    "lint:fix": "eslint src/ content.js --fix",
    "validate": "npm run lint && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "chrome-extension",
    "gmail",
    "audio-recorder",
    "voice-message",
    "transcription",
    "speech-to-text"
  ],
  "author": "Daniel Cregg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielcregg/gmail-audio-recorder.git"
  },
  "bugs": {
    "url": "https://github.com/danielcregg/gmail-audio-recorder/issues"
  },
  "homepage": "https://danielcregg.is-a.dev/gmail-audio-recorder/"
}
